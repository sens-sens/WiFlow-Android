    <!-- Welcome Screen -->
    <string name="welcome_title">Welcome to WiFlow!</string>
    <string name="welcome_content">Learn how to use the app. This guide will show you how to use the app effectively.</string>
    <string name="step1_title">Step 1: Choose a Directory</string>
    <string name="step1_content1">To share files, select a folder from the Home screen.</string>
    <string name="step1_content2">Tap \'Choose Directory\' to pick the folder you want to share.</string>
    <string name="step1_content3">You can update this folder anytime in Settings.</string>
    <string name="step2_title">Step 2: Start and Stop the Server</string>
    <string name="step2_content1">Use the toggle button on the Home screen to start or stop the server.</string>
    <string name="step2_content2">When the server is running, you\'ll see details like FTP Address, Username and Password</string>
    <string name="step2_content3">Ensure your device is connected to the same Wi-Fi as the client.</string>
    <string name="step3_title">Step 3: Use an FTP Client</string>
    <string name="step3_content1">Open an FTP client (e.g., Windows Explorer).</string>
    <string name="step3_content2">Enter the FTP address in this format: ftp://&lt;FTP_ADDRESS&gt;.</string>
    <string name="step3_content3">Use the username and password shown on the Home screen.</string>
    <string name="step3_content4">Start transferring files!</string>
    <string name="ready_title">You\'re Ready to Start!</string>
    <string name="ready_content">Follow these steps anytime to share files with WiFlow.</string>
